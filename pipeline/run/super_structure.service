[Unit]
Description=Super Structure Strategy Live Listener
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/kemal/futures
ExecStart=/usr/bin/python3 -u /home/kemal/futures/pipeline/live/run_super_structure_live.py
Environment=PYTHONUNBUFFERED=1
Restart=always
RestartSec=10
StandardOutput=append:/home/kemal/futures/data/Live/super_structure.log
StandardError=append:/home/kemal/futures/data/Live/super_structure.log

[Install]
WantedBy=default.target
